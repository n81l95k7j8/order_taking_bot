# Set Cloudflare secrets with:
#   npx wrangler secret put TELEGRAM_BOT_TOKEN
#
# For local development, use .dev.vars and do not commit it.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Random webhook verification string (openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=

# Your Telegram user id (@userinfobot)
OWNER_TELEGRAM_ID=
